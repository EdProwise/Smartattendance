{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:tunnel": "concurrently \"bun run dev\" \"node scripts/start-ngrok-cli.js\" \"node scripts/setup-ngrok-env.js\"",
    "build": "bun run build.js",
    "start": "node dist/index.js",
    "lint": "eslint \"**/*.{js,ts}\" && prettier -c \"**/*.{js,ts,json}\"",
    "format": "eslint \"**/*.{js,ts}\" --fix && prettier \"**/*.{js,ts,json}\" --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@supabase/supabase-js": "^2.75.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.2",
    "hono": "^4.9.10",
    "jimp": "^1.6.0",
    "mongoose": "^9.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.25.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.10",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "ngrok": "^5.0.0-beta.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.6.2"
  }
}
